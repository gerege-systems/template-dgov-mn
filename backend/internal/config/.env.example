# APP
PORT=8080
ENVIRONMENT=development
DEBUG=true

# Comma-separated allowed CORS origins. Required in production. Leave empty in dev to fall back to "*".
ALLOWED_ORIGINS=

# DATABASE

# POSTGRE
# dev: DSN (sslmode=disable is OK on localhost only)
# prod: DB_POSTGRE_URL MUST use sslmode=verify-full (CA + hostname checked)
#       — enforced by config validation (secure_system_guide §3.5).
DB_POSTGRE_DRIVER=postgres
DB_POSTGRE_DSN=user=myuser password=mypassword host=myhost port=5432 dbname=mydb sslmode=disable timezone=Asia/Jakarta
DB_POSTGRE_URL=postgres://user:pass@host/db?sslmode=verify-full

# DB pool (optional; defaults 25/5/15)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFE_MINS=15

# JWT — secret MUST be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-string-of-32-or-more-chars
JWT_EXPIRED=5                # access token TTL in hours
JWT_REFRESH_EXPIRED=7        # refresh token TTL in days
JWT_ISSUER=snykk_here

# OTP — кодыг буруу оруулах оролдлогын дээд хязгаар (lockout)
OTP_MAX_ATTEMPTS=5

# bcrypt cost (10–31; default 12 ≈ 100–200ms on 2026 hardware).
BCRYPT_COST=12

# OpenTelemetry tracing — leave OTEL_EXPORTER empty to disable (noop tracer).
# Set "stdout" in dev to print spans, or "otlp" in production with the
# standard OTEL_EXPORTER_OTLP_ENDPOINT env pointing at a collector.
OTEL_EXPORTER=
OTEL_SAMPLE_RATIO=1.0

# CACHE

# REDIS
REDIS_HOST=localhost:6969
REDIS_PASS=mydangdingdong
REDIS_EXPIRED=5
# Trusted reverse-proxy IP/CIDRs (comma-separated). Empty = do NOT trust
# X-Forwarded-For (use peer RemoteAddr) — fail-safe against rate-limit/audit spoofing.
TRUSTED_PROXIES=

# GeregeCloud Verify API — бүх email/SMS OTP (бүртгэл баталгаажуулах + нууц үг
# сэргээх) энэ үйлчилгээгээр явна; SMTP огт ашиглахгүй. Production-д
# VERIFY_API_KEY заавал.
VERIFY_API_BASE=https://verify.gecloud.mn/v1
VERIFY_API_KEY=
VERIFY_CHANNEL=email

# Gerege Verify / XYP (xyp.dgov.mn) — улсын бүртгэлээс байгууллагын мэдээлэл
# авах лавлагаа (eID байгууллага холбоход ашиглана). HTTP Basic Auth. Креденшлгүй
# бол байгууллага холбох функц идэвхгүй (нэвтрэлт/бусад функцэд нөлөөгүй).
XYP_API_BASE=https://xyp.dgov.mn
XYP_CLIENT_ID=
XYP_CLIENT_SECRET=

# OBSERVABILITY_TOKEN — production-д /metrics ба /swagger/doc.json-г хамгаалах
# bearer token. Хоосон бол эдгээр endpoint production-д 404 (бүрэн хаалттай).
OBSERVABILITY_TOKEN=
